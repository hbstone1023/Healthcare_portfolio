### Retention curves
fig, ax = plt.subplots(figsize=(11, 6))

# one line per cohort
cohort_colors = sns.color_palette('crest', n_colors=len(retention_matrix))

for i, (cohort, row) in enumerate(retention_matrix.iterrows()):
    ax.plot(row.index, row.values, marker='o', linewidth=2,
            color=cohort_colors[i], label=cohort, alpha=0.85)

